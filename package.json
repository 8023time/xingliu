{
  "name": "xingliu",
  "version": "1.0.0",
  "description": "星流 - AI 创作者辅助生产与分发平台",
  "keywords": [
    "ai",
    "creator",
    "platform"
  ],
  "homepage": "https://github.com/8023time/xingliu#readme",
  "bugs": {
    "url": "https://github.com/8023time/xingliu/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/8023time/xingliu.git"
  },
  "license": "ISC",
  "author": "8023time",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "concurrently -n proxy,turbo \"pnpm dev:proxy\" \"turbo run dev\"",
    "dev:web": "turbo run dev --filter=@xingliu/web",
    "dev:admin": "turbo run dev --filter=@xingliu/admin",
    "dev:server": "turbo run dev --filter=@xingliu/server",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@xingliu/web",
    "build:admin": "turbo run build --filter=@xingliu/admin",
    "build:server": "turbo run build --filter=@xingliu/server",
    "build:config": "turbo run build --filter=@xingliu/config",
    "lint:eslint": "turbo run lint:eslint",
    "lint:oxc": "oxlint",
    "lint": "pnpm lint:oxc && pnpm lint:eslint",
    "lint:prettier": "prettier --write \"{apps,server,packages,libs}/**/*.{js,ts,mjs,cjs,json,jsx,tsx,css,less,scss,vue,html,md}\"",
    "dev:proxy": "caddy run --config Caddyfile",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/md5": "^2.3.6",
    "commitizen": "^4.3.1",
    "concurrently": "^10.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "oxlint": "^1.66.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.14",
    "typescript-eslint": "^8.59.4"
  },
  "dependencies": {
    "dayjs": "^1.11.21",
    "md5": "^2.3.0"
  }
}
