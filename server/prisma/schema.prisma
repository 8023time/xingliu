generator client {
  provider     = "prisma-client"
  output       = "../libs/common/src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE   @map("active")
  DISABLED @map("disabled")
  DELETED  @map("deleted")
}

enum Visibility {
  PRIVATE @map("private")
  PUBLIC  @map("public")
  SYSTEM  @map("system")
}

enum CommonStatus {
  ACTIVE   @map("active")
  DISABLED @map("disabled")
  DELETED  @map("deleted")
}

enum AssetType {
  IMAGE    @map("image")
  VIDEO    @map("video")
  DOCUMENT @map("document")
  LINK     @map("link")
  AUDIO    @map("audio")
}

enum SafetyStatus {
  PENDING @map("pending")
  PASS    @map("pass")
  REJECT  @map("reject")
}

enum RiskLevel {
  NONE   @map("none")
  LOW    @map("low")
  MEDIUM @map("medium")
  HIGH   @map("high")
}

enum ContentType {
  ARTICLE    @map("article")
  IMAGE_TEXT @map("image_text")
  SHORT_POST @map("short_post")
}

enum ContentStatus {
  DRAFT        @map("draft")
  REVIEWING    @map("reviewing")
  NEED_REWRITE @map("need_rewrite")
  REJECTED     @map("rejected")
  APPROVED     @map("approved")
  PUBLISHED    @map("published")
  OFFLINE      @map("offline")
}

enum QualityLevel {
  S @map("S")
  A @map("A")
  B @map("B")
  C @map("C")
  D @map("D")
}

enum ChangeType {
  CREATE   @map("create")
  EDIT     @map("edit")
  REWRITE  @map("rewrite")
  ROLLBACK @map("rollback")
}

enum DraftSyncStatus {
  SYNCED   @map("synced")
  PENDING  @map("pending")
  CONFLICT @map("conflict")
}

enum DraftSavedFrom {
  AUTO         @map("auto")
  MANUAL       @map("manual")
  OFFLINE_SYNC @map("offline_sync")
}

enum AiTaskType {
  GENERATE     @map("generate")
  MODERATE     @map("moderate")
  SCORE        @map("score")
  REWRITE      @map("rewrite")
  ASSET_CHECK  @map("asset_check")
  IMAGE_PROMPT @map("image_prompt")
}

enum AiTaskStatus {
  PENDING @map("pending")
  RUNNING @map("running")
  SUCCESS @map("success")
  FAILED  @map("failed")
}

enum SafetyReviewDecision {
  PASS         @map("pass")
  NEED_REWRITE @map("need_rewrite")
  REJECT       @map("reject")
}

enum InteractionType {
  VIEW    @map("view")
  LIKE    @map("like")
  SHARE   @map("share")
  COLLECT @map("collect")
  DISLIKE @map("dislike")
  REPORT  @map("report")
}

enum TopicSource {
  MANUAL @map("manual")
  API    @map("api")
}

enum TopicStatus {
  ACTIVE  @map("active")
  EXPIRED @map("expired")
  HIDDEN  @map("hidden")
}

enum DistributionStatus {
  PENDING @map("pending")
  SUCCESS @map("success")
  FAILED  @map("failed")
}

model User {
  id           String     @id @default(uuid())
  email        String?    @unique
  phone        String     @unique
  passwordHash String     @map("password_hash")
  username     String
  avatarUrl    String?    @map("avatar_url")
  status       UserStatus @default(ACTIVE)
  tokenVersion Int        @default(0) @map("token_version")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  promptTemplates        PromptTemplate[]
  assets                 Asset[]
  contents               Content[]
  contentVersionsCreated ContentVersion[]
  draftSnapshots         DraftSnapshot[]
  aiTasks                AiTask[]
  rewriteRecords         RewriteRecord[]
  interactions           ContentInteraction[]

  @@index([status])
  @@map("users")
}

model PromptTemplate {
  id              String       @id @default(uuid())
  ownerId         String?      @map("owner_id")
  name            String
  category        String
  description     String?
  template        String
  variablesSchema Json?        @map("variables_schema")
  modelConfig     Json?        @map("model_config")
  visibility      Visibility   @default(PRIVATE)
  usageCount      Int          @default(0) @map("usage_count")
  status          CommonStatus @default(ACTIVE)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  owner   User?    @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  aiTasks AiTask[]

  @@index([ownerId, updatedAt])
  @@index([category, visibility])
  @@index([status])
  @@map("prompt_templates")
}

model Asset {
  id              String       @id @default(uuid())
  userId          String       @map("user_id")
  type            AssetType
  name            String
  url             String
  storageKey      String       @map("storage_key")
  mimeType        String?      @map("mime_type")
  sizeBytes       Int?         @map("size_bytes")
  tags            Json?
  aiDescription   String?      @map("ai_description")
  metadata        Json?
  safetyStatus    SafetyStatus @default(PENDING) @map("safety_status")
  safetyRiskLevel RiskLevel?   @map("safety_risk_level")
  safetyLabels    Json?        @map("safety_labels")
  safetyReason    String?      @map("safety_reason")
  safetyRawOutput Json?        @map("safety_raw_output")
  safetyCheckedAt DateTime?    @map("safety_checked_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiTasks       AiTask[]
  coverContents Content[]
  coverVersions ContentVersion[]

  @@index([userId, createdAt])
  @@index([type])
  @@index([safetyStatus])
  @@map("assets")
}

model Content {
  id                 String        @id @default(uuid())
  authorId           String        @map("author_id")
  contentType        ContentType   @map("content_type")
  title              String
  summary            String?
  coverAssetId       String?       @map("cover_asset_id")
  currentVersionId   String?       @unique @map("current_version_id")
  publishedVersionId String?       @unique @map("published_version_id")
  status             ContentStatus @default(DRAFT)
  safetyStatus       SafetyStatus  @default(PENDING) @map("safety_status")
  qualityLevel       QualityLevel? @map("quality_level")
  qualityScore       Decimal?      @map("quality_score") @db.Decimal(6, 2)
  safetyScore        Decimal?      @map("safety_score") @db.Decimal(6, 2)
  publishedAt        DateTime?     @map("published_at")
  offlineAt          DateTime?     @map("offline_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  deletedAt          DateTime?     @map("deleted_at")

  author             User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  coverAsset         Asset?               @relation(fields: [coverAssetId], references: [id], onDelete: SetNull)
  versions           ContentVersion[]     @relation("ContentVersions")
  currentVersion     ContentVersion?      @relation("CurrentContentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  publishedVersion   ContentVersion?      @relation("PublishedContentVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)
  draftSnapshots     DraftSnapshot[]
  aiTasks            AiTask[]
  safetyReviews      SafetyReview[]
  qualityEvaluations QualityEvaluation[]
  rewriteRecords     RewriteRecord[]
  metrics            ContentMetric?
  interactions       ContentInteraction[]
  distributionTasks  DistributionTask[]

  @@index([authorId, updatedAt])
  @@index([status, publishedAt])
  @@index([qualityScore])
  @@map("contents")
}

model ContentVersion {
  id            String     @id @default(uuid())
  contentId     String     @map("content_id")
  versionNo     Int        @map("version_no")
  title         String
  summary       String?
  body          String
  bodyJson      Json?      @map("body_json")
  assetIds      Json?      @map("asset_ids")
  coverAssetId  String?    @map("cover_asset_id")
  changeType    ChangeType @map("change_type")
  changeSummary String?    @map("change_summary")
  createdBy     String?    @map("created_by")
  createdAt     DateTime   @default(now()) @map("created_at")

  content              Content             @relation("ContentVersions", fields: [contentId], references: [id], onDelete: Cascade)
  currentForContent    Content?            @relation("CurrentContentVersion")
  publishedForContent  Content?            @relation("PublishedContentVersion")
  coverAsset           Asset?              @relation(fields: [coverAssetId], references: [id], onDelete: SetNull)
  creator              User?               @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  basedDraftSnapshots  DraftSnapshot[]
  safetyReviews        SafetyReview[]
  qualityEvaluations   QualityEvaluation[]
  rewriteSourceRecords RewriteRecord[]     @relation("RewriteSourceVersion")
  rewriteTargetRecords RewriteRecord[]     @relation("RewriteTargetVersion")

  @@unique([contentId, versionNo])
  @@index([contentId, createdAt])
  @@map("content_versions")
}

model DraftSnapshot {
  id             String          @id @default(uuid())
  contentId      String          @map("content_id")
  userId         String          @map("user_id")
  baseVersionId  String?         @map("base_version_id")
  title          String
  body           String
  bodyJson       Json?           @map("body_json")
  assetIds       Json?           @map("asset_ids")
  clientRevision Int             @default(1) @map("client_revision")
  serverRevision Int             @default(1) @map("server_revision")
  syncStatus     DraftSyncStatus @default(SYNCED) @map("sync_status")
  savedFrom      DraftSavedFrom  @default(AUTO) @map("saved_from")
  createdAt      DateTime        @default(now()) @map("created_at")

  content     Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseVersion ContentVersion? @relation(fields: [baseVersionId], references: [id], onDelete: SetNull)

  @@index([contentId, createdAt])
  @@index([userId, createdAt])
  @@map("draft_snapshots")
}

model AiTask {
  id            String       @id @default(uuid())
  userId        String?      @map("user_id")
  contentId     String?      @map("content_id")
  assetId       String?      @map("asset_id")
  promptId      String?      @map("prompt_id")
  taskType      AiTaskType   @map("task_type")
  status        AiTaskStatus @default(PENDING)
  modelProvider String       @map("model_provider")
  modelName     String?      @map("model_name")
  inputSummary  String?      @map("input_summary")
  outputSummary String?      @map("output_summary")
  inputHash     String?      @map("input_hash")
  tokenInput    Int?         @map("token_input")
  tokenOutput   Int?         @map("token_output")
  durationMs    Int?         @map("duration_ms")
  errorCode     String?      @map("error_code")
  errorMessage  String?      @map("error_message")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  content            Content?            @relation(fields: [contentId], references: [id], onDelete: Cascade)
  asset              Asset?              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  prompt             PromptTemplate?     @relation(fields: [promptId], references: [id], onDelete: SetNull)
  safetyReviews      SafetyReview[]
  qualityEvaluations QualityEvaluation[]
  rewriteRecords     RewriteRecord[]

  @@index([taskType, status])
  @@index([contentId, createdAt])
  @@index([userId, createdAt])
  @@map("ai_tasks")
}

model SafetyReview {
  id                String               @id @default(uuid())
  contentId         String               @map("content_id")
  contentVersionId  String               @map("content_version_id")
  aiTaskId          String?              @map("ai_task_id")
  decision          SafetyReviewDecision
  riskLevel         RiskLevel            @map("risk_level")
  riskCategories    Json?                @map("risk_categories")
  riskSpans         Json?                @map("risk_spans")
  ruleHits          Json?                @map("rule_hits")
  safetyScore       Decimal              @map("safety_score") @db.Decimal(6, 2)
  reason            String?
  suggestions       Json?
  provider          String               @default("aliyun_green")
  providerRequestId String?              @map("provider_request_id")
  rawProviderOutput Json?                @map("raw_provider_output")
  createdAt         DateTime             @default(now()) @map("created_at")

  content        Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentVersion ContentVersion @relation(fields: [contentVersionId], references: [id], onDelete: Cascade)
  aiTask         AiTask?        @relation(fields: [aiTaskId], references: [id], onDelete: SetNull)

  @@index([contentId, createdAt])
  @@index([contentVersionId])
  @@index([decision, createdAt])
  @@map("safety_reviews")
}

model QualityEvaluation {
  id               String       @id @default(uuid())
  contentId        String       @map("content_id")
  contentVersionId String       @map("content_version_id")
  aiTaskId         String?      @map("ai_task_id")
  totalScore       Decimal      @map("total_score") @db.Decimal(6, 2)
  level            QualityLevel
  standardVersion  String       @map("standard_version")
  dimensions       Json
  summary          String?
  improvements     Json?
  createdAt        DateTime     @default(now()) @map("created_at")

  content        Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  contentVersion ContentVersion @relation(fields: [contentVersionId], references: [id], onDelete: Cascade)
  aiTask         AiTask?        @relation(fields: [aiTaskId], references: [id], onDelete: SetNull)

  @@index([contentId, createdAt])
  @@index([totalScore])
  @@map("quality_evaluations")
}

model RewriteRecord {
  id                 String   @id @default(uuid())
  contentId          String   @map("content_id")
  userId             String?  @map("user_id")
  sourceVersionId    String   @map("source_version_id")
  rewrittenVersionId String?  @map("rewritten_version_id")
  aiTaskId           String?  @map("ai_task_id")
  rewrittenTitle     String   @map("rewritten_title")
  rewrittenBody      String   @map("rewritten_body")
  changedSpans       Json?    @map("changed_spans")
  reason             String?
  accepted           Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at")

  content          Content         @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  sourceVersion    ContentVersion  @relation("RewriteSourceVersion", fields: [sourceVersionId], references: [id], onDelete: Cascade)
  rewrittenVersion ContentVersion? @relation("RewriteTargetVersion", fields: [rewrittenVersionId], references: [id], onDelete: SetNull)
  aiTask           AiTask?         @relation(fields: [aiTaskId], references: [id], onDelete: SetNull)

  @@index([contentId, createdAt])
  @@map("rewrite_records")
}

model ContentMetric {
  contentId    String   @id @map("content_id")
  viewCount    Int      @default(0) @map("view_count")
  likeCount    Int      @default(0) @map("like_count")
  shareCount   Int      @default(0) @map("share_count")
  collectCount Int      @default(0) @map("collect_count")
  reportCount  Int      @default(0) @map("report_count")
  updatedAt    DateTime @updatedAt @map("updated_at")

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_metrics")
}

model ContentInteraction {
  id         String          @id @default(uuid())
  userId     String?         @map("user_id")
  contentId  String          @map("content_id")
  actionType InteractionType @map("action_type")
  value      String?
  metadata   Json?
  createdAt  DateTime        @default(now()) @map("created_at")

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId, actionType])
  @@index([userId, createdAt])
  @@map("content_interactions")
}

model HotTopic {
  id         String      @id @default(uuid())
  externalId String?     @map("external_id")
  title      String
  source     TopicSource
  sourceName String?     @map("source_name")
  category   String?
  heatScore  Decimal     @map("heat_score") @db.Decimal(12, 4)
  url        String?
  metadata   Json?
  startedAt  DateTime?   @map("started_at")
  endedAt    DateTime?   @map("ended_at")
  status     TopicStatus @default(ACTIVE)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@unique([sourceName, externalId])
  @@index([status, heatScore])
  @@map("hot_topics")
}

model DistributionTask {
  id                String             @id @default(uuid())
  contentId         String             @map("content_id")
  platform          String
  status            DistributionStatus @default(PENDING)
  requestPayload    Json?              @map("request_payload")
  responsePayload   Json?              @map("response_payload")
  externalContentId String?            @map("external_content_id")
  errorMessage      String?            @map("error_message")
  distributedAt     DateTime?          @map("distributed_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId, createdAt])
  @@index([platform, status])
  @@map("distribution_tasks")
}
