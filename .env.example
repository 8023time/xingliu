# Database
DB_USER=xingliu
DB_PASSWORD=your_secure_password_here
DB_NAME=xingliu_db

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400

# Alibaba Cloud Content Moderation
ALIBABA_CLOUD_ACCESS_KEY_ID=your_ram_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_ram_access_key_secret
ALIYUN_GREEN_ENDPOINT=https://green-cip.cn-shanghai.aliyuncs.com
ALIYUN_GREEN_TEXT_SERVICE=ai_art_detection
ALIYUN_GREEN_IMAGE_SERVICE=baselineCheck

# Volcengine Ark OpenAI-compatible Model via @langchain/openai
OPENAI_API_KEY=your_volcengine_ark_api_key
OPENAI_BASE_URL=https://your_volcengine_ark_openai_compatible_endpoint
OPENAI_MODEL=your_volcengine_ark_endpoint_or_model_id

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
ADMIN_API_URL=http://localhost:3000

# Node Environment
NODE_ENV=production
